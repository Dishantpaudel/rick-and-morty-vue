{
    "name": "my-app-vue",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs --fix --ignore-path .gitignore",
        "format": "prettier --write \"src/**/*.{js,vue,css}\"",
        "prepare": "husky"
    },
    "dependencies": {
        "vue": "^3.5.30"
    },
    "devDependencies": {
        "@vitejs/plugin-vue": "^6.0.5",
        "eslint": "^10.1.0",
        "eslint-plugin-vue": "^10.8.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "prettier": "^3.8.1",
        "vite": "^8.0.1"
    },
    "lint-staged": {
        "src/**/*.{js,vue}": [
            "eslint --fix",
            "prettier --write"
        ],
        "src/**/*.css": [
            "prettier --write"
        ]
    }
}