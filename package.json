{
    "name": "my-app-vue",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build --configLoader native --emptyOutDir false",
        "preview": "vite preview",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write \"src/**/*.{js,vue,css}\"",
        "format:check": "prettier --check \"src/**/*.{js,vue,css}\"",
        "prepare": "husky",
        "test": "vitest run --config vitest.config.js --configLoader native",
        "test:all": "vitest run",
        "test:storybook": "npx playwright install chromium --with-deps && vitest run --project storybook",
        "storybook": "storybook dev -p 6006",
        "build-storybook": "storybook build"
    },
    "dependencies": {
        "storybook": "^10.3.3",
        "vue": "^3.5.30"
    },
    "devDependencies": {
        "@chromatic-com/storybook": "^5.1.1",
        "@eslint/js": "^10.0.1",
        "@storybook/addon-a11y": "^10.3.3",
        "@storybook/addon-docs": "^10.3.3",
        "@storybook/addon-onboarding": "^10.3.3",
        "@storybook/addon-vitest": "^10.3.3",
        "@storybook/vue3-vite": "^10.3.3",
        "@vitejs/plugin-vue": "^6.0.5",
        "@vitest/browser-playwright": "^4.1.0",
        "@vitest/coverage-v8": "^4.1.0",
        "@vue/eslint-config-prettier": "^10.2.0",
        "@vue/test-utils": "^2.4.6",
        "eslint": "^10.1.0",
        "eslint-plugin-storybook": "^10.3.3",
        "eslint-plugin-vue": "^10.8.0",
        "globals": "^17.4.0",
        "husky": "^9.1.7",
        "jsdom": "^29.0.1",
        "lint-staged": "^16.4.0",
        "playwright": "^1.58.2",
        "prettier": "^3.8.1",
        "vite": "^8.0.1",
        "vitest": "^4.1.0"
    },
    "lint-staged": {
        "src/**/*.{js,vue}": [
            "eslint --fix",
            "prettier --write"
        ],
        "src/**/*.css": [
            "prettier --write"
        ]
    },
    "eslintConfig": {
        "extends": [
            "plugin:storybook/recommended"
        ]
    }
}
